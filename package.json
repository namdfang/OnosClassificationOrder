{
  "name": "printsel",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "deploy": "pnpm run build && pm2 reload ecosystem.config.js",
    "be-deploy": "pnpm run build:api && pm2 reload ecosystem.config.js",
    "fe-deploy": "pnpm run build:web",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:vercel": "turbo run lint && turbo run build-types && mkdir dist || true && touch ./dist/index.html && echo 'Done'",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "build-types": "turbo run build-types",
    "dev:api": "turbo run dev --filter ./apps/api",
    "build:api": "turbo run build --filter ./apps/api",
    "dev:web": "turbo run dev --filter ./apps/web",
    "build:web": "turbo run build --filter ./apps/web",
    "start:api": "pnpm --filter ./apps/api start:prod",
    "start:web": "pnpm --filter ./apps/web start:prod",
    "start": "concurrently \"pnpm run start:api\" \"pnpm run start:web\" ",
    "dev:core": "turbo run dev --filter core",
    "dev:shared": "turbo run dev --filter shared",
    "spell": "cspell . --no-progress --cache",
    "_postinstall": "manypkg check",
    "prepare": "husky install",
    "clean-node-modules": "rm -rf ./node_modules && rm -rf ./apps/*/node_modules && rm -rf ./packages/*/node_modules",
    "clean-dist": "rm -rf ./packages/*/dist",
    "reset": "pnpm clean-dist && pnpm --filter ./apps/api i"
  },
  "engines": {
    "node": "20.20.2"
  },
  "packageManager": "pnpm@8.6.10",
  "pnpm": {
    "overrides": {
      "passport": "0.6.0",
      "@types/node": "20.17.17"
    }
  },
  "dependencies": {
    "@commitlint/cli": "^18.2.0",
    "@commitlint/config-conventional": "^17.6.6",
    "@cspell/dict-vi-vn": "^3.0.0",
    "@manypkg/cli": "^0.21.0",
    "@nestjs/cli": "^10.1.11",
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.99",
    "concurrently": "^8.2.1",
    "cspell": "^8.0.0",
    "eslint": "^9.30.0",
    "husky": "^8.0.3",
    "lint-staged": "~15.1.0",
    "prettier": "^3.0.3",
    "swc-loader": "^0.2.3",
    "tsconfig": "^7.0.0",
    "turbo": "latest"
  }
}
