{
  "name": "folinas-fe",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "NODE_OPTIONS=\"--max-old-space-size=${NODE_HEAP_MB:-4096}\" vite build && rimraf ./dist-prod && mkdir ./dist-prod && cp -rf ./dist/* ./dist-prod/",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx --cache",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --cache",
    "prettier": "prettier --check \"src/**/(*.tsx|*.ts|*.css|*.scss)\"",
    "prettier:fix": "prettier --write \"src/**/(*.tsx|*.ts|*.css|*.scss)\"",
    "preview": "vite preview --host --port 5173",
    "pre-commit": "npm run format && npm run lint",
    "build-types": "tsc --noEmit -p tsconfig.build.json"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ]
  },
  "overrides": {
    "nanoid": "5.0.7"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.14.5",
    "axios": "^1.4.0",
    "big.js": "^6.2.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "d3-dsv": "^2.0.0",
    "dayjs": "^1.11.9",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^0.378.0",
    "moment": "^2.29.4",
    "nanoid": "5.0.7",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-barcode": "^1.5.3",
    "react-beautiful-dnd": "^13.1.1",
    "react-custom-scrollbars": "^4.2.1",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.53.0",
    "react-otp-input": "^3.0.2",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.14.1",
    "recharts": "^2.7.2",
    "shared": "workspace:*",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.0.0",
    "type-fest": "^4.17.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/d3-dsv": "^3.0.7",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20.12.7",
    "@types/prop-types": "^15.7.12",
    "@types/react": "^18.3.0",
    "@types/react-custom-scrollbars": "^4.0.13",
    "@types/react-dom": "^18.2.21",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.56.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.24",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.5",
    "vite": "^4.3.9"
  }
}
