  "scripts": {
    "upgrade:package": "ncu -u",
    "prebuild": "rimraf dist",
    "build": "nest build -b swc && rimraf ./dist-prod && mkdir ./dist-prod && cp -rf ./dist/* ./dist-prod/",
    "deploy": "pnpm build && pnpm start:prod",
    "build:prod": "tsc -p tsconfig.build.json",
    "build:win": "nest build -b swc",
    "postbuild:prod": "copyfiles --up 1 src/**/*.json dist",
    "dev0": "nest start -b swc -w",
    "dev": "nodemon -w \"../../packages/**/*.ts\" -w \"../../apps/**/*.ts\" -e ts --exec 'pnpm build && node ./start.js'",
    "devb": "nodemon -w \"../../packages/**/*.ts\" -w \"../../apps/**/*.ts\" -e ts --exec 'pnpm build && bun ./start.js'",
    "dev:win": "nodemon -w \"../../packages/**/*.ts\" -w \"../../apps/**/*.ts\" -e ts --exec \"pnpm build:win && node ./start.js\"",
    "devz": "rspack build --watch",
    "dev2": "nest start --watch",
    "dev:vite": "pnpm vite",
    "start:dev": "ts-node src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist-prod/main.js",
    "lint": "eslint . --ext .ts --cache",
    "lint:fix": "eslint --fix . --ext .ts --cache",
    "build-types": "pnpm tsc --noEmit -p tsconfig.build.json",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:cov": "NODE_ENV=test jest --coverage",
    "test:debug": "NODE_ENV=test node --inspect-brk -r ts-node/register node_modules/.bin/jest --runInBand",
    "copy:lib": "cpx 'src/lib/**/{files,workspace}/**/*.*' dist/lib && cpx 'src/lib/**/{files,workspace}/**/.!(gitignore)' dist/lib",
    "test:e2e": "NODE_ENV=test jest --config ./test/jest-e2e.json",
    "seed": "ts-node ./src/seed/seed-runner.ts",
    "_prepare": "husky install"
  },
  "packageManager": "pnpm@8.6.10",
