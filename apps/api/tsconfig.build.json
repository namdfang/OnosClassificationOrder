{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      // `@core/*` cần cho type-check (`pnpm build-types`): các file trong
      // packages/core tự import `@core/...` — thiếu alias là TS2307. Build
      // prod dùng swc (nest build -b swc), không đọc paths ở đây.
      "@core/*": ["../../packages/core/*"],
      "@shared/*": ["../../packages/shared/*"]
      // "core": ["../../packages/core/"],
      // "shared": ["../../packages/shared/"]
    }
  },
  "exclude": ["node_modules", "test", "**/*spec.ts", "src/metadata.ts", "dist"]
}
