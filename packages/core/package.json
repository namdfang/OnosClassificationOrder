{
  "name": "core",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "pnpm run build",
    "prebuild": "rimraf dist",
    "build": "pnpm tsup index.ts --format cjs",
    "dev": "pnpm run build --watch",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "build-types": "pnpm tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/s3-request-presigner": "^3.369.0",
    "@nestjs/common": "^10.3.5",
    "@nestjs/core": "^10.2.7",
    "@nestjs/mongoose": "10.0.1",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/swagger": "^7.3.0",
    "@smithy/node-http-handler": "^2.5.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cheerio": "1.0.0-rc.12",
    "class-transformer": "~0.5.1",
    "class-validator": "~0.14.0",
    "fastify": "^4.26.2",
    "fastify-multer": "^2.0.3",
    "form-data": "^4.0.0",
    "libphonenumber-js": "^1.10.49",
    "lodash": "^4.17.21",
    "mongoose": "^7.6.10",
    "nanoid": "^3.3.7",
    "nestjs-i18n": "^10.2.6",
    "qs": "^6.11.2",
    "rxjs": "^7.8.1",
    "shared": "workspace:*",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@printsel/eslint-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/lodash": "^4.14.200",
    "@types/node": "^20.8.2",
    "@types/uuid": "^9.0.1",
    "eslint": "^9.30.0",
    "rimraf": "^5.0.1",
    "tsconfig": "7.0.0",
    "tsup": "^7.2.0",
    "typescript": "^5.0.2"
  },
  "engines": {
    "node": "20.20.2"
  }
}
