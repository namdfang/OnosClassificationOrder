{
  "name": "shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./index.d.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "postinstall": "pnpm run build",
    "prebuild": "rimraf dist",
    "build": "pnpm tsup index.ts --format cjs,esm",
    "dev": "pnpm run build --watch",
    "lint": "eslint --ext .ts . --cache",
    "lint:vercel": "eslint --ext .ts . --cache && mkdir dist && touch ./dist/index.html",
    "lint:fix": "eslint --ext .js,.jsx,.ts . --fix --cache",
    "build-types": "pnpm tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.99",
    "@types/big.js": "^6.2.2",
    "eslint": "^8.49.0",
    "eslint-config-custom": "0.0.0",
    "rimraf": "^5.0.1",
    "tsconfig": "workspace:*",
    "tsup": "^7.2.0",
    "type-fest": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@anatine/zod-nestjs": "^2.0.8",
    "@anatine/zod-openapi": "^2.2.5",
    "axios": "^1.6.8",
    "big.js": "^6.2.1",
    "dayjs": "^1.11.10",
    "nanoid": "^3.3.7",
    "zod": "^3.22.4"
  }
}